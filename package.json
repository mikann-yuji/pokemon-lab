{
  "name": "pokemon-lab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sqlite:assets": "node scripts/copy-sqlite-wasm-assets.mjs && node scripts/export-sqlite-catalog-db.mjs",
    "db:init": "node scripts/init-db.mjs",
    "predev": "npm run sqlite:assets && npm run db:init",
    "dev": "next dev",
    "prebuild": "npm run sqlite:assets && npm run db:init",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seeds:fetch": "node scripts/fetch-pokeapi-seeds.mjs && node scripts/fetch-pokeapi-items.mjs && node scripts/fetch-champions-items.mjs && node scripts/fetch-champions-move-usage.mjs",
    "seeds:validate": "node scripts/validate-pokeapi-seeds.mjs",
    "champions:fetch": "node scripts/fetch-champions-seed.mjs && node scripts/fetch-champions-items.mjs && node scripts/fetch-champions-move-usage.mjs",
    "items:fetch": "node scripts/fetch-pokeapi-items.mjs && node scripts/fetch-champions-items.mjs",
    "champions-items:fetch": "node scripts/fetch-champions-items.mjs",
    "champions-moves:fetch": "node scripts/fetch-champions-move-usage.mjs",
    "champions-icons:fetch": "node scripts/fetch-champions-icons.mjs"
  },
  "dependencies": {
    "@smogon/calc": "^0.11.0",
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "better-sqlite3": "^12.11.1",
    "downshift": "^9.4.0",
    "firebase": "^12.16.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cheerio": "^1.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4.3.2",
    "typescript": "^5"
  }
}
