{
  "name": "pokemon-lab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db:init": "node scripts/init-db.mjs",
    "predev": "npm run db:init",
    "dev": "next dev",
    "prebuild": "npm run db:init",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seeds:fetch": "node scripts/fetch-pokeapi-seeds.mjs && node scripts/fetch-pokeapi-items.mjs && node scripts/fetch-champions-items.mjs",
    "seeds:validate": "node scripts/validate-pokeapi-seeds.mjs",
    "champions:fetch": "node scripts/fetch-champions-seed.mjs && node scripts/fetch-champions-items.mjs",
    "items:fetch": "node scripts/fetch-pokeapi-items.mjs && node scripts/fetch-champions-items.mjs",
    "champions-items:fetch": "node scripts/fetch-champions-items.mjs"
  },
  "dependencies": {
    "@smogon/calc": "^0.11.0",
    "better-sqlite3": "^12.11.1",
    "dexie": "^4.4.4",
    "downshift": "^9.4.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cheerio": "^1.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4.3.2",
    "typescript": "^5"
  }
